# Set these in the CropSense backend service on Railway. Never commit values.
ENVIRONMENT=production
PORT=8000
JWT_SECRET=
OPENAI_API_KEY=
OPENWEATHER_API_KEY=

# Replace both URLs after Vercel assigns the frontend domain.
FRONTEND_ORIGINS=https://your-project.vercel.app
FRONTEND_URL=https://your-project.vercel.app

# Generate a Railway public domain, then include it plus the healthcheck host.
ALLOWED_HOSTS=your-api.up.railway.app,healthcheck.railway.app,127.0.0.1,localhost

DATABASE_URL=sqlite:////app/data/cropsense.db
MODEL_PATH=models/rice_disease_model.keras
ALLOW_HEURISTIC_FALLBACKS=false
FORCE_HTTPS=false

# Create a Railway Redis service named Redis and use reference variables:
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}
REDIS_USE_RATE_LIMITING=true

METRICS_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
