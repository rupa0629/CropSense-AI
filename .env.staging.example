ENVIRONMENT=staging
JWT_SECRET=
OPENAI_API_KEY=
OPENWEATHER_API_KEY=
FRONTEND_ORIGINS=https://your-staging-project.vercel.app
FRONTEND_URL=https://your-staging-project.vercel.app
ALLOWED_HOSTS=your-staging-api.up.railway.app,healthcheck.railway.app
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
RUN_DATABASE_MIGRATIONS=true
MODEL_PATH=models/rice_disease_model.keras
ALLOW_HEURISTIC_FALLBACKS=false
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USE_RATE_LIMITING=true
METRICS_TOKEN=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
ANALYSIS_RETENTION_DAYS=730
WEATHER_RETENTION_DAYS=365
CHAT_RETENTION_DAYS=90
