{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "api_server.py",
      "config/**",
      "middleware/**",
      "models/**",
      "observability/**",
      "routers/**",
      "services/**",
      "utils/**",
      "scripts/**",
      "requirements.txt",
      "Dockerfile",
      "railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health/ready",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 0,
    "drainingSeconds": 20
  }
}
