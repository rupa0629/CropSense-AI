# CropSense AI environment configuration
# Development configuration. Use .env.production.example for production.

ENVIRONMENT=development
# Generate a strong JWT secret using: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET=
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1
OPENAI_API_KEY=
OPENWEATHER_API_KEY=

# Database configuration
# For development: sqlite:///cropsense.db
# CropSense currently supports SQLite only. Production Compose persists this
# database in a named volume and it must be backed up regularly.
DATABASE_URL=sqlite:///cropsense.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

MODEL_PATH=models/rice_disease_model.keras
MODEL_USE_GPU=false
MODEL_CPU_INTER_THREADS=1
MODEL_CPU_INTRA_THREADS=2
MODEL_GPU_MEMORY_LIMIT_MB=
FORCE_HTTPS=false
ALLOW_HEURISTIC_FALLBACKS=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
MAX_UPLOAD_SIZE_BYTES=5242880
ALLOWED_UPLOAD_CONTENT_TYPES=image/jpeg,image/png,image/webp

# Email configuration for password reset
# SMTP settings (e.g., Gmail, SendGrid, AWS SES, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true
FRONTEND_URL=http://localhost:5173

# Redis configuration for distributed rate limiting
# Set REDIS_USE_RATE_LIMITING=true to enable Redis-based rate limiting for production
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_USE_RATE_LIMITING=false
